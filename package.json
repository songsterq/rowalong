{
  "name": "rowalong",
  "version": "1.0.0",
  "description": "RowAlong — rowing intervals that ride on top of whatever you're watching.",
  "main": "electron/app.cjs",
  "keywords": [],
  "author": "Endless Rain Studio",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pack": "npm run build && electron-builder",
    "pack:dir": "npm run build && electron-builder --dir",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "harness": "vitest run -c tools/overlay-harness.config.ts",
    "spike:electron": "electron electron/main.cjs",
    "electron:dev": "concurrently -k -n vite,electron \"vite\" \"wait-on tcp:5173 && electron electron/app.cjs\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  }
}
